<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="WinAgent" Manufacturer="Bluscream" Version="2.13.0" UpgradeCode="2455A1F6-65DF-453D-940E-07498EA34293" Scope="perMachine">
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." AllowSameVersionUpgrades="yes" />
    
    <MediaTemplate EmbedCab="yes" />
    
    <Icon Id="AppIcon" SourceFile="..\assets\icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />

    <!-- Standard directory structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="WinAgent" />
    </StandardDirectory>

    <ComponentGroup Id="AppComponents" Directory="INSTALLFOLDER">
      <!-- 1. WinAgent Service Component (natively registered and controlled) -->
      <Component Id="ServiceComponent" Guid="418F7B5E-E420-4C9D-B1DF-31620BF0FEF0">
        <File Id="ServiceExe" Source="$(var.ServicePublishDir)\WinAgent.Service.exe" KeyPath="yes" />
        
        <ServiceInstall 
          Id="ServiceInstaller" 
          Type="ownProcess" 
          Name="WinAgent" 
          DisplayName="WinAgent" 
          Description="Windows Agent for providing MQTT, MCP and API control" 
          Start="auto" 
          ErrorControl="normal" 
          Account="LocalSystem">
          <ServiceDependency Id="Tcpip" />
        </ServiceInstall>
        
        <!-- Controls starting, stopping, and deleting the service natively -->
        <ServiceControl 
          Id="ServiceController" 
          Name="WinAgent" 
          Start="install" 
          Stop="both" 
          Remove="uninstall" 
          Wait="yes" />
      </Component>

      <!-- 2. appsettings.json Component (NeverOverwrite=yes keeps user configurations safe during updates) -->
      <Component Id="ConfigComponent" Guid="D27C218B-7756-427D-B27D-FA7D878A9C12" NeverOverwrite="yes">
        <File Id="AppSettingsJson" Source="$(var.ServicePublishDir)\appsettings.json" KeyPath="yes" />
      </Component>

      <!-- 3. WinAgent Tray Companion Component (adds startup Registry Run Key) -->
      <Component Id="TrayComponent" Guid="A76FD242-76A3-41A8-B6B1-39F241775E01">
        <File Id="TrayExe" Source="$(var.TrayPublishDir)\WinAgent.Tray.exe" KeyPath="yes" />
        <File Id="TrayDll" Source="$(var.TrayPublishDir)\WinAgent.Tray.dll" />
        <RegistryValue Root="HKLM" Key="Software\Microsoft\Windows\CurrentVersion\Run" Name="WinAgent.Tray" Type="string" Value="&quot;[INSTALLFOLDER]WinAgent.Tray.exe&quot;" />
      </Component>

      <!-- 4. WinAgent CLI Component (adds INSTALLFOLDER to system environment PATH) -->
      <Component Id="CliComponent" Guid="98F1D2C6-E715-4D02-A62E-0C49F3010FA2">
        <File Id="CliExe" Source="$(var.CliPublishDir)\winagent.exe" KeyPath="yes" />
        <File Id="CliDll" Source="$(var.CliPublishDir)\winagent.dll" />
        <Environment Id="AddPath" Action="set" Name="PATH" Value="[INSTALLFOLDER]" Part="last" System="yes" />
      </Component>

      <Files Include="$(var.ServicePublishDir)\**">
        <Exclude Files="$(var.ServicePublishDir)\WinAgent.Service.exe" />
        <Exclude Files="$(var.ServicePublishDir)\appsettings.json" />
        <Exclude Files="**\WinAgent.Service.exe" />
        <Exclude Files="**\appsettings.json" />
        <Exclude Files="WinAgent.Service.exe" />
        <Exclude Files="appsettings.json" />
      </Files>
    </ComponentGroup>
    
    <!-- Feature definition -->
    <Feature Id="MainFeature" Title="WinAgent Application Suite" Level="1">
      <ComponentGroupRef Id="AppComponents" />
    </Feature>
  </Package>
</Wix>













