<Project Sdk="WixToolset.Sdk/5.0.2">
  <PropertyGroup>
    <!-- We generate an x64 package -->
    <OutputName>WinAgent-Installer</OutputName>
    <OutputType>Package</OutputType>
    <Platform>x64</Platform>
    <Platforms>x64</Platforms>
  </PropertyGroup>

  <!-- Reference our 3 application projects so MSBuild/WiX publishes them automatically before harvesting -->
  <ItemGroup>
    <ProjectReference Include="..\WinAgent.Service\WinAgent.Service.csproj" Publish="true" />
    <ProjectReference Include="..\WinAgent.Tray\WinAgent.Tray.csproj" Publish="true" />
    <ProjectReference Include="..\WinAgent.CLI\WinAgent.CLI.csproj" Publish="true" />
  </ItemGroup>
</Project>
