<Project Sdk="WixToolset.Sdk/5.0.2">
  <PropertyGroup>
    <!-- We generate an x64 package -->
    <OutputName>WinAgent-Installer</OutputName>
    <OutputType>Package</OutputType>
    <Platform>x64</Platform>
    <Platforms>x64</Platforms>
    <SuppressIces>ICE61</SuppressIces>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\WinAgent.Service\WinAgent.Service.csproj" />
    <ProjectReference Include="..\WinAgent.Tray\WinAgent.Tray.csproj" />
    <ProjectReference Include="..\WinAgent.CLI\WinAgent.CLI.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <DefineConstants>ServicePublishDir=..\WinAgent.Service\bin\Release\net9.0-windows10.0.19041.0\win-x64\publish;TrayPublishDir=..\WinAgent.Tray\bin\Release\net9.0-windows10.0.19041.0\win-x64\publish;CliPublishDir=..\WinAgent.CLI\bin\Release\net9.0-windows10.0.19041.0\win-x64\publish</DefineConstants>
  </PropertyGroup>
</Project>
